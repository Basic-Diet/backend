    {
      "name": "3. Subscription Meal Planner Menu - Canonical",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "function walk(node, path, matches) {",
              "  if (node === null || node === undefined) return;",
              "  if (Array.isArray(node)) {",
              "    node.forEach((item, index) => walk(item, path + \"[\" + index + \"]\", matches));",
              "    return;",
              "  }",
              "  if (typeof node === \"object\") {",
              "    const targetProductKey = pm.environment.get(\"targetProductKey\");",
              "    const targetProductName = pm.environment.get(\"targetProductName\");",
              "    const targetCategoryKey = pm.environment.get(\"targetCategoryKey\");",
              "    const targetCategoryName = pm.environment.get(\"targetCategoryName\");",
              "",
              "    const values = [",
              "      node.key,",
              "      node.slug,",
              "      node.name,",
              "      node.nameEn,",
              "      node.nameAr,",
              "      node.title,",
              "      node.label,",
              "      node.productKey,",
              "      node.categoryKey,",
              "      node.sectionKey",
              "    ].filter(Boolean).map(String).map(v => v.toLowerCase());",
              "",
              "    const targets = [",
              "      targetProductKey,",
              "      targetProductName,",
              "      targetCategoryKey,",
              "      targetCategoryName",
              "    ].filter(Boolean).map(String).map(v => v.toLowerCase());",
              "",
              "    const hit = targets.length > 0 && targets.some(t => values.some(v => v.includes(t)));",
              "",
              "    if (hit) {",
              "      matches.push({",
              "        path,",
              "        key: node.key || node.productKey || node.categoryKey || node.sectionKey,",
              "        name: node.name || node.nameEn || node.nameAr || node.title || node.label,",
              "        selectionType: node.selectionType,",
              "        action: node.action,",
              "        optionGroupsLength: Array.isArray(node.optionGroups) ? node.optionGroups.length : undefined",
              "      });",
              "    }",
              "",
              "    Object.keys(node).forEach(k => walk(node[k], path + \".\" + k, matches));",
              "  }",
              "}",
              "",
              "const json = pm.response.json();",
              "const matches = [];",
              "walk(json, \"$\", matches);",
              "console.log(\"TARGET_MATCHES\", matches);",
              "",
              "pm.test(\"Target search completed\", function () {",
              "  pm.expect(matches).to.be.an(\"array\");",
              "});",
              "",
              "if ((pm.environment.get(\"targetProductKey\") || pm.environment.get(\"targetProductName\") || pm.environment.get(\"targetCategoryKey\") || pm.environment.get(\"targetCategoryName\"))) {",
              "  pm.test(\"Target product/category exists in this response\", function () {",
              "    pm.expect(matches.length, JSON.stringify(matches, null, 2)).to.be.greaterThan(0);",
              "  });",
              "}",
              "",
              "pm.test(\"Response format checks\", function() {",
              "   if(json.data && json.data.builderCatalog) {",
              "       var version = json.data.builderCatalog.contractVersion;",
              "       if(version) {",
              "           pm.expect(version).to.be.a(\"string\");",
              "       }",
              "   }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{apiBase}}/subscriptions/meal-planner-menu?lang={{lang}}",
          "host": [
            "{{apiBase}}"
          ],
          "path": [
            "subscriptions",
            "meal-planner-menu"
          ],
          "query": [
            {
              "key": "lang",
              "value": "{{lang}}"
            }
          ]
        }
      }
    },
