{
  "info": {
    "name": "Subscription Delivery QA",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 Auth",
      "item": [
        {
          "name": "Customer Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"{{clientPhone}}\", \"password\": \"{{clientPassword}}\"}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"Has token\", () => pm.expect(json.token).to.be.a(\"string\"));",
                  "pm.environment.set(\"clientToken\", json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Dashboard Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{adminEmail}}\", \"password\": \"{{adminPassword}}\"}"
            },
            "url": "{{baseUrl}}/auth/dashboard/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"Has token\", () => pm.expect(json.token).to.be.a(\"string\"));",
                  "pm.environment.set(\"adminToken\", json.token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 First-Day Pickup Override",
      "item": [
        {
          "name": "Timeline",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "url": "{{baseUrl}}/subscriptions/{{subscriptionId_pickupOverride}}/timeline"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"Day 1 is today\", () => pm.expect(json.days[0].date).to.eql(\"{{day1Date}}\"));",
                  "pm.test(\"Day 1 fulfillmentType is pickup\", () => pm.expect(json.days[0].fulfillmentType).to.eql(\"pickup\"));",
                  "pm.test(\"Day 2 fulfillmentType is delivery\", () => pm.expect(json.days[1].fulfillmentType).to.eql(\"delivery\"));"
                ]
              }
            }
          ]
        },
        {
          "name": "Day 1 Fulfillment Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "url": "{{baseUrl}}/subscriptions/{{subscriptionId_pickupOverride}}/days/{{day1Date}}/fulfillment-status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"fulfillmentType is pickup\", () => pm.expect(json.fulfillmentType).to.eql(\"pickup\"));",
                  "pm.test(\"status is pending\", () => pm.expect(json.status).to.eql(\"pending\"));"
                ]
              }
            }
          ]
        },
        {
          "name": "Day 1 Pickup Availability",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "url": "{{baseUrl}}/subscriptions/{{subscriptionId_pickupOverride}}/days/{{day1Date}}/pickup-availability"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"available is true\", () => pm.expect(json.available).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Day 1 Pickup Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"branchId\": \"{{branchId}}\"}"
            },
            "url": "{{baseUrl}}/subscriptions/{{subscriptionId_pickupOverride}}/days/{{day1Date}}/pickup-request"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test(\"Has pickupRequestId\", () => pm.expect(json._id).to.be.a(\"string\"));",
                  "pm.environment.set(\"pickupRequestId\", json._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Pickup Request Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "url": "{{baseUrl}}/pickup-requests/{{pickupRequestId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"status is pending\", () => pm.expect(json.status).to.eql(\"pending\"));",
                  "pm.test(\"branchId matches\", () => pm.expect(json.branchId).to.eql(pm.environment.get(\"branchId\")));"
                ]
              }
            }
          ]
        },
        {
          "name": "Day 2 Pickup Availability Must Fail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "url": "{{baseUrl}}/subscriptions/{{subscriptionId_pickupOverride}}/days/{{day2Date}}/pickup-availability"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"available is false\", () => pm.expect(json.available).to.be.false);"
                ]
              }
            }
          ]
        },
        {
          "name": "Day 2 Pickup Request Must Fail",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"branchId\": \"{{branchId}}\"}"
            },
            "url": "{{baseUrl}}/subscriptions/{{subscriptionId_pickupOverride}}/days/{{day2Date}}/pickup-request"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 400\", () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test(\"errorCode is INVALID_DELIVERY_MODE\", () => pm.expect(json.errorCode).to.eql(\"INVALID_DELIVERY_MODE\"));"
                ]
              }
            }
          ]
        },
        {
          "name": "Courier Queue Day 1 Exclusion Check",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/courier/queue?date={{day1Date}}",
              "host": ["{{baseUrl}}"],
              "path": ["courier", "queue"],
              "query": [{ "key": "date", "value": "{{day1Date}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const customerId = pm.environment.get(\"customerId\");",
                  "const found = json.items && json.items.some(item => item.customerId === customerId);",
                  "pm.test(\"Customer NOT in courier queue for day1 (pickup override)\", () => pm.expect(found).to.be.false);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 Delivery Only Today",
      "item": [
        {
          "name": "Timeline must start tomorrow",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "url": "{{baseUrl}}/subscriptions/{{subscriptionId_deliveryOnly}}/timeline"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"First day is tomorrow\", () => pm.expect(json.days[0].date).to.eql(pm.environment.get(\"tomorrow\")));",
                  "pm.test(\"All days are delivery\", () => {",
                  "  json.days.forEach(d => pm.expect(d.fulfillmentType).to.eql(\"delivery\"));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Courier Queue today must not include same-day delivery",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/courier/queue?date={{today}}",
              "host": ["{{baseUrl}}"],
              "path": ["courier", "queue"],
              "query": [{ "key": "date", "value": "{{today}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "const subId = pm.environment.get(\"subscriptionId_deliveryOnly\");",
                  "const found = json.items && json.items.some(item => item.subscriptionId === subId);",
                  "pm.test(\"Delivery-only subscription NOT in today's courier queue\", () => pm.expect(found).to.be.false);"
                ]
              }
            }
          ]
        }
      ]
    },
